# Get a key at https://resend.com — free tier works for portfolio contact forms.
RESEND_API_KEY=

# Where contact form submissions are delivered (defaults to devershikam@gmail.com if unset).
CONTACT_TO_EMAIL=devershikam@gmail.com

# Optional: after verifying a domain in Resend, use your own from-address:
# CONTACT_FROM_EMAIL=Portfolio <hello@yourdomain.com>

# Optional: canonical site URL for metadata (also set in Vercel for production).
# NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
